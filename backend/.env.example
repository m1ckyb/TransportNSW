# --- TransportNSW API Configuration ---
TFNSW_API_KEY=your_api_key_here
# Mode can be: sydneytrains, buses, ferries, lightrail, etc.
TFNSW_MODE=sydneytrains

# --- MQTT Configuration (for Home Assistant) ---
MQTT_URL=mqtt://localhost
MQTT_USER=
MQTT_PASS=

# Comma-separated list of Stop IDs to monitor via MQTT
MONITORED_STOPS=200060

# --- Server Configuration ---
PORT=3001
