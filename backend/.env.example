# --- TransportNSW API Configuration ---
# Provide at least one key. You can add up to 5 for rotation.
TFNSW_API_KEY_1=your_first_api_key_here
TFNSW_API_KEY_2=
TFNSW_API_KEY_3=
TFNSW_API_KEY_4=
TFNSW_API_KEY_5=
# Legacy support for single key
TFNSW_API_KEY=
# Mode can be: sydneytrains, buses, ferries, lightrail, etc.
TFNSW_MODE=sydneytrains

# --- MQTT Configuration (for Home Assistant) ---
MQTT_URL=mqtt://localhost
MQTT_USER=
MQTT_PASS=

# Comma-separated list of Stop IDs to monitor via MQTT
MONITORED_STOPS=200060

# --- Server Configuration ---
PORT=3001
